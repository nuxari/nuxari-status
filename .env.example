# ─── Nuxari Status Page — Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in the values for your environment.
# NEVER commit .env.local — it is already in .gitignore.

# ── Public (exposed to the browser) ──────────────────────────────────────────

# URL of this status page
NEXT_PUBLIC_STATUS_PAGE_URL=https://status.nuxari.com

# Backend API URL (public status endpoints)
NEXT_PUBLIC_STATUS_API_URL=https://api.nuxari.com

# Nuxari app and marketing site URLs
NEXT_PUBLIC_APP_URL=https://app.nuxari.com
NEXT_PUBLIC_WWW_URL=https://nuxari.com
NEXT_PUBLIC_DOCS_URL=https://nuxari.com/docs
NEXT_PUBLIC_SUPPORT_URL=https://app.nuxari.com/admin/support/tickets/new

# ── Server-side only (NOT exposed to the browser) ────────────────────────────
# Used by the /api/health-check route to run live health checks.
# Keep these server-only — never prefix with NEXT_PUBLIC_.

NUXARI_API_URL=https://api.nuxari.com
NUXARI_APP_URL=https://app.nuxari.com
NUXARI_WWW_URL=https://nuxari.com
NUXARI_DOCS_URL=https://nuxari.com/docs
NUXARI_AUTH_HEALTH_URL=https://api.nuxari.com/api/auth/status
NUXARI_SUPPORT_REQUEST_URL=https://app.nuxari.com/admin/support/tickets/new
